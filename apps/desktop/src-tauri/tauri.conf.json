{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Agent Workbench",
  "version": "1.0.0",
  "identifier": "com.agentworkbench.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Personal Agent Workbench",
        "label": "main",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      },
      {
        "title": "Spotlight",
        "label": "spotlight",
        "url": "?spotlight=true",
        "width": 750,
        "height": 450,
        "center": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
